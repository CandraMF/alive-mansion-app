generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// A. MASTER DATA (KATEGORI, WARNA, UKURAN)
// ==========================================

model Category {
  id        String     @id @default(cuid())
  name      String     // Contoh: "Men", "Outerwear"
  slug      String     @unique // Contoh: "men", "outerwear" (untuk URL)
  
  // Nested / Self-Relation untuk sub-kategori
  parentId  String?    
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  
  products  Product[]  
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Color {
  id        String    @id @default(cuid())
  name      String    // Contoh: "Black", "Red / White"
  
  // Fitur Array dari PostgreSQL: Bisa menyimpan banyak warna!
  // Jika "Red / White", isinya: ["#FF0000", "#FFFFFF"]
  hexCodes  String[]  
  
  variants  Variant[] 
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Size {
  id        String    @id @default(cuid())
  name      String    // Contoh: "S", "M", "OS"
  
  // sortOrder digunakan agar dropdown terurut benar (bukan abjad)
  // Contoh: S = 1, M = 2, L = 3, OS = 99
  sortOrder Int       @default(0)
  
  variants  Variant[] 
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


// ==========================================
// B. TRANSAKSI & KATALOG (PRODUK, VARIAN)
// ==========================================

model Product {
  id          String         @id @default(cuid())
  name        String
  description String         @db.Text
  price       Int            
  status      String         @default("PUBLISHED") // PUBLISHED, DRAFT, ARCHIVED
  
  // Relasi Kategori (Opsional, bisa saja produk belum punya kategori)
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  
  // Relasi
  variants    Variant[]
  images      ProductImage[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// --- TABEL GAMBAR PRODUK ---
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  
  // Menentukan jenis gambar (Contoh: "MAIN", "WITH_MODEL", "DETAIL")
  category  String   @default("MAIN") 
  
  // Tetap pertahankan position untuk urutan tampilan di galeri
  position  Int      @default(0) 
  
  createdAt DateTime @default(now())
}

model Variant {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // Relasi ke Master Size & Color
  sizeId      String
  size        Size        @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  
  colorId     String
  color       Color       @relation(fields: [colorId], references: [id], onDelete: Restrict)
  
  // Menggunakan stock (angka) jauh lebih aman untuk e-commerce
  stock       Int         @default(0) 
  sku         String?     @unique 
  
  orderItems  OrderItem[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ==========================================
// C. PESANAN (ORDER)
// ==========================================

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerEmail String
  totalAmount   Int
  status        String      @default("PENDING") 
  xenditInvoice String?     
  
  items         OrderItem[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  variantId String
  variant   Variant  @relation(fields: [variantId], references: [id])
  
  quantity  Int
  priceAt   Int      // Mencatat harga saat barang dibeli
}