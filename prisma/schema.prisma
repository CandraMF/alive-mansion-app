generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique

  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Color {
  id   String @id @default(cuid())
  name String

  hexCodes String[]

  variants Variant[]

  images ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Size {
  id   String @id @default(cuid())
  name String

  sortOrder Int @default(0)

  variants Variant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String @id @default(cuid())
  name        String
  description String @db.Text
  status      String @default("PUBLISHED")

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  variants Variant[]
  images   ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorId String?
  color   Color?  @relation(fields: [colorId], references: [id], onDelete: SetNull)

  url String

  category String @default("MAIN")

  position Int @default(0)

  createdAt DateTime @default(now())
}

model Variant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sizeId String
  size   Size   @relation(fields: [sizeId], references: [id], onDelete: Restrict)

  colorId String
  color   Color  @relation(fields: [colorId], references: [id], onDelete: Restrict)

  isMain Boolean @default(false)

  stock Int     @default(0)
  price Int     @default(0)
  sku   String? @unique

  orderItems OrderItem[]

  blocks Block[]

  cartItems CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id            String  @id @default(cuid())
  customerName  String
  customerEmail String
  totalAmount   Int
  status        String  @default("PENDING")
  xenditInvoice String?

  items OrderItem[]

  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity Int
  priceAt  Int
}

model Page {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  isPublished Boolean @default(false)

  metaTitle       String? @db.Text
  metaDescription String? @db.Text
  ogImage         String? @db.Text

  customFonts Json? @default("[]")

  sections Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id     String @id @default(cuid())
  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  name     String
  position Int    @default(0)

  content Json @default("{}")

  blocks Block[]
}

model Block {
  id        String  @id @default(cuid())
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  type     String
  position Int    @default(0)

  content Json @default("{}")

  children Json? @default("[]")

  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model ThemeSetting {
  id String @id @default(uuid())

  key String @unique @default("global")

  navbar Json?

  footer Json?

  global Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  STAFF
  CUSTOMER
}

enum Permission {
  ACCESS_DASHBOARD
  ACCESS_CMS
  READ_PRODUCTS
  WRITE_PRODUCTS
  READ_ORDERS
  WRITE_ORDERS
  MANAGE_PROMOS
  MANAGE_CUSTOMERS
  MANAGE_SETTINGS
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  password String?

  role        Role         @default(CUSTOMER)
  permissions Permission[]

  accounts  Account[]
  sessions  Session[]
  cartItems CartItem[]

  vouchers UserVoucher[]

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum PromoType {
  PERCENTAGE
  NOMINAL
  SHIPPING
}

enum PromoAudience {
  ALL_USERS
  NEW_USERS_ONLY
  SPECIFIC_USERS
}

enum VoucherStatus {
  AVAILABLE
  USED
  EXPIRED
}

model Promo {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  type        PromoType
  value       Float
  maxDiscount Float?
  minPurchase Float     @default(0)

  audience PromoAudience @default(ALL_USERS)

  claimedVouchers UserVoucher[]

  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)

  quotaTotal       Int?
  quotaUsed        Int  @default(0)
  maxClaimsPerUser Int  @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserVoucher {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  promoId String
  promo   Promo  @relation(fields: [promoId], references: [id], onDelete: Cascade)

  status VoucherStatus @default(AVAILABLE)

  usedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  quantity Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, variantId])
}
