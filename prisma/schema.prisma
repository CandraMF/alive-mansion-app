generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// A. MASTER DATA (KATEGORI, WARNA, UKURAN)
// ==========================================

model Category {
  id        String     @id @default(cuid())
  name      String     // Contoh: "Men", "Outerwear"
  slug      String     @unique // Contoh: "men", "outerwear" (untuk URL)
  
  // Nested / Self-Relation untuk sub-kategori
  parentId  String?    
  parent    Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children  Category[] @relation("SubCategories")
  
  products  Product[]  
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Color {
  id        String    @id @default(cuid())
  name      String    // Contoh: "Black", "Red / White"
  
  // Fitur Array dari PostgreSQL: Bisa menyimpan banyak warna!
  // Jika "Red / White", isinya: ["#FF0000", "#FFFFFF"]
  hexCodes  String[]  
  
  variants  Variant[] 

  images    ProductImage[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Size {
  id        String    @id @default(cuid())
  name      String    // Contoh: "S", "M", "OS"
  
  // sortOrder digunakan agar dropdown terurut benar (bukan abjad)
  // Contoh: S = 1, M = 2, L = 3, OS = 99
  sortOrder Int       @default(0)
  
  variants  Variant[] 
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


// ==========================================
// B. TRANSAKSI & KATALOG (PRODUK, VARIAN)
// ==========================================

model Product {
  id          String         @id @default(cuid())
  name        String
  description String         @db.Text
  status      String         @default("PUBLISHED") // PUBLISHED, DRAFT, ARCHIVED
  
  // Relasi Kategori (Opsional, bisa saja produk belum punya kategori)
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  
  // Relasi
  variants    Variant[]
  images      ProductImage[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// --- TABEL GAMBAR PRODUK ---
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorId   String?  
  color     Color?   @relation(fields: [colorId], references: [id], onDelete: SetNull)

  url       String
  
  // Menentukan jenis gambar (Contoh: "MAIN", "WITH_MODEL", "DETAIL")
  category  String   @default("MAIN") 
  
  // Tetap pertahankan position untuk urutan tampilan di galeri
  position  Int      @default(0) 
  
  createdAt DateTime @default(now())
}

model Variant {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  // Relasi ke Master Size & Color
  sizeId      String
  size        Size        @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  
  colorId     String
  color       Color       @relation(fields: [colorId], references: [id], onDelete: Restrict)

  isMain      Boolean     @default(false)
  
  // Menggunakan stock (angka) jauh lebih aman untuk e-commerce
  stock       Int         @default(0) 
  price       Int         @default(0)
  sku         String?     @unique 
  
  orderItems  OrderItem[]

  blocks      Block[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ==========================================
// C. PESANAN (ORDER)
// ==========================================

model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerEmail String
  totalAmount   Int
  status        String      @default("PENDING") 
  xenditInvoice String?     
  
  items         OrderItem[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  variantId String
  variant   Variant  @relation(fields: [variantId], references: [id])
  
  quantity  Int
  priceAt   Int      // Mencatat harga saat barang dibeli
}

// ==========================================
// CMS (CONTENT MANAGEMENT SYSTEM) MODELS
// ==========================================

model Page {
  id              String    @id @default(cuid())
  title           String    // Nama halaman di admin
  slug            String    @unique // URL endpoint
  isPublished     Boolean   @default(false)
  
  metaTitle       String?   @db.Text
  metaDescription String?   @db.Text
  ogImage         String?   @db.Text

  sections        Section[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Section {
  id          String    @id @default(cuid())
  pageId      String
  page        Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  name        String    // Label untuk admin (misal: "Hero Banner", "Grid Best Seller")
  layout      String    @default("CONTAINER") // Opsi: FULL_WIDTH, CONTAINER
  paddingY    String    @default("py-12")     // Jarak atas bawah
  background  String?   // Warna latar belakang opsional
  
  position    Int       @default(0) // Urutan section dari atas ke bawah
  
  blocks      Block[]
}

model Block {
  id          String    @id @default(cuid())
  sectionId   String
  section     Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  
  type        String    // Tipe komponen dari Registry (misal: "FEATURED_GRID", "TEXT_BLOCK")
  position    Int       @default(0) // Urutan elemen di dalam section
  
  // Jantung CMS: Menyimpan data dinamis seperti text, array variantIds, dll
  content     Json      @default("{}") 
  
  // Relasi tunggal opsional (berguna jika blok murni hanya showcase 1 varian)
  variantId   String?
  variant     Variant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

// ==========================================
// GLOBAL SETTINGS (Header, Footer, Config)
// ==========================================

model StoreSettings {
  // Kita hanya akan menyimpan 1 baris data di tabel ini
  id        String   @id @default("global") 
  
  // Semua struktur menu navigasi, link sosial media, dan teks footer disimpan di sini
  content   Json     @default("{}") 
  
  updatedAt DateTime @updatedAt
}